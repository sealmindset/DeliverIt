# DeliverIt Environment Configuration
# Copy this file to .env and fill in the values

# === Auth (OIDC) ===
OIDC_ISSUER_URL=http://localhost:3009
OIDC_CLIENT_ID=mock-oidc-client
OIDC_CLIENT_SECRET=mock-oidc-secret

# JWT signing secret -- Generate with: openssl rand -hex 32
JWT_SECRET=

# === Database ===
DATABASE_URL=postgresql://deliverit:deliverit@localhost:5436/deliverit

# === Backend ===
BACKEND_URL=http://localhost:8002
FRONTEND_URL=http://localhost:3002

# === Mock Services (local development) ===
MOCK_OIDC_URL=http://localhost:3009
JIRA_BASE_URL=http://localhost:8443
JIRA_AUTH_TOKEN=mock-jira-token

# === Production (replace mock values above) ===
# OIDC_ISSUER_URL=https://login.microsoftonline.com/{tenant-id}/v2.0
# OIDC_CLIENT_ID=your-azure-app-client-id
# OIDC_CLIENT_SECRET=your-azure-app-client-secret
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_AUTH_TOKEN=your-jira-api-token
